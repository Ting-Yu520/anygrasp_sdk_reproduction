**/__pycache__/**
# Python 编译缓存
__pycache__/
*.pyc
*.pyo
*.so

# 编译构建目录
build/
dist/
*.egg-info/

# 编译临时文件
*.o
*.d
*.obj
*.lib
*.exp
*.ilk
*.pdb
*.log
.ninja_deps
.ninja_log

# Conda 环境目录（不要上传）
env/
.conda/

# 数据集和模型权重（避免上传大文件）
*.pth
*.tar
*.zip
*.ply
*.npy
*.npz

# License 相关文件（敏感）
*.lic
*license*
*License*
*public_key*
*signature*

# 其他临时文件
.DS_Store
*.swp
*.swo
*~**/*.egg-info/
*.o
*.so
*.egg
.DS_Store
.TimeRecord
license
